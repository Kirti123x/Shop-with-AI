# Copy this file to .env and fill in your real key
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# The "Get my size" body-measurement pipeline is now a separate deployable
# service (see measurement-service/) so this main backend stays lightweight
# and doesn't need PyTorch/ultralytics installed locally. Deploy that folder
# to a cloud host (Hugging Face Spaces recommended - see its README) and put
# the resulting URL here:
MEASUREMENT_PIPELINE_URL=http://127.0.0.1:9001/estimate
